{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "chapter-manifest.schema.json",
  "$defs": {
    "Reference": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "minLength": 1,
          "title": "Id",
          "type": "string"
        },
        "path": {
          "minLength": 1,
          "title": "Path",
          "type": "string"
        }
      },
      "required": [
        "id",
        "path"
      ],
      "title": "Reference",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "title": "$Schema",
      "type": "string"
    },
    "schemaVersion": {
      "const": 1,
      "title": "Schemaversion",
      "type": "integer"
    },
    "kind": {
      "const": "chapterManifest",
      "title": "Kind",
      "type": "string"
    },
    "id": {
      "minLength": 1,
      "title": "Id",
      "type": "string"
    },
    "number": {
      "title": "Number",
      "type": "integer"
    },
    "title": {
      "title": "Title",
      "type": "string"
    },
    "isPublic": {
      "title": "Ispublic",
      "type": "boolean"
    },
    "versions": {
      "items": {
        "$ref": "#/$defs/Reference"
      },
      "minItems": 1,
      "title": "Versions",
      "type": "array"
    }
  },
  "required": [
    "$schema",
    "schemaVersion",
    "kind",
    "id",
    "number",
    "title",
    "isPublic",
    "versions"
  ],
  "title": "ChapterManifestDocument",
  "type": "object"
}
