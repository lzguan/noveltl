{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "content-version-manifest.schema.json",
  "$defs": {
    "ArtifactReference": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "minLength": 1,
          "title": "Id",
          "type": "string"
        },
        "path": {
          "minLength": 1,
          "title": "Path",
          "type": "string"
        },
        "kind": {
          "minLength": 1,
          "title": "Kind",
          "type": "string"
        }
      },
      "required": [
        "id",
        "path",
        "kind"
      ],
      "title": "ArtifactReference",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "title": "$Schema",
      "type": "string"
    },
    "schemaVersion": {
      "const": 1,
      "title": "Schemaversion",
      "type": "integer"
    },
    "kind": {
      "const": "contentVersionManifest",
      "title": "Kind",
      "type": "string"
    },
    "id": {
      "minLength": 1,
      "title": "Id",
      "type": "string"
    },
    "number": {
      "minimum": 1,
      "title": "Number",
      "type": "integer"
    },
    "text": {
      "minLength": 1,
      "title": "Text",
      "type": "string"
    },
    "artifacts": {
      "items": {
        "$ref": "#/$defs/ArtifactReference"
      },
      "title": "Artifacts",
      "type": "array"
    }
  },
  "required": [
    "$schema",
    "schemaVersion",
    "kind",
    "id",
    "number",
    "text",
    "artifacts"
  ],
  "title": "ContentVersionManifestDocument",
  "type": "object"
}
