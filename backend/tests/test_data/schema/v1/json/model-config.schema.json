{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "model-config.schema.json",
  "$defs": {
    "CluenerParameters": {
      "additionalProperties": false,
      "properties": {
        "chunkSize": {
          "maximum": 512,
          "minimum": 1,
          "title": "Chunksize",
          "type": "integer"
        },
        "forceChunk": {
          "title": "Forcechunk",
          "type": "boolean"
        },
        "separators": {
          "additionalProperties": {
            "enum": [
              "high",
              "med",
              "low"
            ],
            "type": "string"
          },
          "title": "Separators",
          "type": "object"
        }
      },
      "required": [
        "chunkSize",
        "forceChunk",
        "separators"
      ],
      "title": "CluenerParameters",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "title": "$Schema",
      "type": "string"
    },
    "schemaVersion": {
      "const": 1,
      "title": "Schemaversion",
      "type": "integer"
    },
    "kind": {
      "const": "modelConfig",
      "title": "Kind",
      "type": "string"
    },
    "id": {
      "minLength": 1,
      "title": "Id",
      "type": "string"
    },
    "configType": {
      "const": "ner",
      "title": "Configtype",
      "type": "string"
    },
    "modelName": {
      "const": "cluener",
      "title": "Modelname",
      "type": "string"
    },
    "parameters": {
      "$ref": "#/$defs/CluenerParameters"
    }
  },
  "required": [
    "$schema",
    "schemaVersion",
    "kind",
    "id",
    "configType",
    "modelName",
    "parameters"
  ],
  "title": "ModelConfigDocument",
  "type": "object"
}
