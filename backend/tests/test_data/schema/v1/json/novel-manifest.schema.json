{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "novel-manifest.schema.json",
  "$defs": {
    "ChapterReference": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "minLength": 1,
          "title": "Id",
          "type": "string"
        },
        "path": {
          "minLength": 1,
          "title": "Path",
          "type": "string"
        },
        "number": {
          "title": "Number",
          "type": "integer"
        }
      },
      "required": [
        "id",
        "path",
        "number"
      ],
      "title": "ChapterReference",
      "type": "object"
    },
    "Provenance": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "minLength": 1,
          "title": "Kind",
          "type": "string"
        },
        "creator": {
          "minLength": 1,
          "title": "Creator",
          "type": "string"
        },
        "license": {
          "minLength": 1,
          "title": "License",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "creator",
        "license"
      ],
      "title": "Provenance",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "title": "$Schema",
      "type": "string"
    },
    "schemaVersion": {
      "const": 1,
      "title": "Schemaversion",
      "type": "integer"
    },
    "kind": {
      "const": "novelManifest",
      "title": "Kind",
      "type": "string"
    },
    "id": {
      "minLength": 1,
      "title": "Id",
      "type": "string"
    },
    "title": {
      "minLength": 1,
      "title": "Title",
      "type": "string"
    },
    "description": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Description"
    },
    "author": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Author"
    },
    "languageCode": {
      "minLength": 1,
      "title": "Languagecode",
      "type": "string"
    },
    "novelType": {
      "enum": [
        "original",
        "translation",
        "other"
      ],
      "title": "Noveltype",
      "type": "string"
    },
    "visibility": {
      "enum": [
        "private",
        "restricted",
        "unlisted",
        "public"
      ],
      "title": "Visibility",
      "type": "string"
    },
    "provenance": {
      "$ref": "#/$defs/Provenance"
    },
    "chapters": {
      "items": {
        "$ref": "#/$defs/ChapterReference"
      },
      "title": "Chapters",
      "type": "array"
    }
  },
  "required": [
    "$schema",
    "schemaVersion",
    "kind",
    "id",
    "title",
    "description",
    "author",
    "languageCode",
    "novelType",
    "visibility",
    "provenance",
    "chapters"
  ],
  "title": "NovelManifestDocument",
  "type": "object"
}
