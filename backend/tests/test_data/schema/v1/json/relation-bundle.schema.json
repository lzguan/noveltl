{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "relation-bundle.schema.json",
  "$defs": {
    "SourceWorkDocument": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "minLength": 1,
          "title": "Id",
          "type": "string"
        },
        "title": {
          "minLength": 1,
          "title": "Title",
          "type": "string"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Description"
        },
        "novels": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Novels",
          "type": "array"
        }
      },
      "required": [
        "id",
        "title",
        "description",
        "novels"
      ],
      "title": "SourceWorkDocument",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "title": "$Schema",
      "type": "string"
    },
    "schemaVersion": {
      "const": 1,
      "title": "Schemaversion",
      "type": "integer"
    },
    "kind": {
      "const": "relationBundle",
      "title": "Kind",
      "type": "string"
    },
    "id": {
      "minLength": 1,
      "title": "Id",
      "type": "string"
    },
    "sourceWorks": {
      "items": {
        "$ref": "#/$defs/SourceWorkDocument"
      },
      "title": "Sourceworks",
      "type": "array"
    }
  },
  "required": [
    "$schema",
    "schemaVersion",
    "kind",
    "id",
    "sourceWorks"
  ],
  "title": "RelationBundleDocument",
  "type": "object"
}
