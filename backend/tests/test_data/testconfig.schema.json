{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "required": ["models"],
    "additionalProperties": false,
    "properties": {
        "$schema": {
            "type": "string",
            "description": "JSON Schema reference for editor validation."
        },
        "models": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "cluener": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                        "chunk_size": {
                            "type": "integer",
                            "minimum": 1,
                            "maximum": 512,
                            "default": 500,
                            "description": "Max tokens per chunk passed to the NER model."
                        },
                        "separators": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string",
                                "enum": ["high", "med", "low"]
                            },
                            "description": "Character -> priority mapping for text chunking. Higher priority separators are preferred chunk boundaries."
                        },
                        "force_chunk": {
                            "type": "boolean",
                            "default": false,
                            "description": "Force break mid-sentence when no separator is found within chunk_size tokens."
                        }
                    }
                }
            }
        }
    }
}
