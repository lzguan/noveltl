#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BACKEND_DIR="$(dirname "$SCRIPT_DIR")/../backend"

# Get alembic current revision
ALEMBIC_REV=$(cd "$BACKEND_DIR" && alembic current 2>/dev/null | awk '{print $1}')

DATE=$(date +%Y-%m-%d_%H%M%S)
FILENAME="backup_${DATE}_${ALEMBIC_REV}.sql"

if ! PGPASSWORD="$DB_PASSWORD" \
  pg_dump -h "$DB_HOST" -p "${DB_INTERNAL_PORT:-5432}" -U "$DB_USER" "$DB_NAME" > "$SCRIPT_DIR/$FILENAME"; then
  rm -f "$SCRIPT_DIR/$FILENAME"
  echo "Backup failed, cleaned up partial file"
  exit 1
fi

echo "Backup saved to $SCRIPT_DIR/$FILENAME"
