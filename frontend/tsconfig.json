{
	"references": [{ "path": "./tsconfig.app.json" }, { "path": "./tsconfig.node.json" }],
	"compilerOptions": {
		"paths": {
			"@/*": ["./src/*"]
		},
		"strict": true,
		"exactOptionalPropertyTypes": true,
		"types": [],
		"plugins": [
			{
				"name": "@effect/language-service"
			}
		]
	},
	"include": ["src"],
	"exclude": ["**/node_modules/**"]
}
